#!/bin/sh
INIT_NAME="PGenerator"
PROGRAM_NAME="PGenerator"
PROGRAM_DAEMON_SOCKET="/usr/sbin/PGeneratord.pl"
PROGRAM_CLIENT_SERIAL="/usr/bin/PGenerator_serial.pl"
PROGRAM_DAEMON_VIDEO="/usr/sbin/PGeneratord"
PROGRAM_CLIENT_CMD="/usr/bin/PGenerator_cmd.pl"
PGENERATOR_USER_GROUP="pgenerator"
PGENERATOR_VAR_DIR="/var/lib/PGenerator"
PGENERATOR_MOUNT_POINT_DIR="/var/lib/PGenerator/running"
PGENERATOR_MOUNT_POINT_NAME="PGeneratorTmpFs"
PGENERATOR_TMPFS_SIZE="20M"
PGENERATOR_PID_DIR="/var/run/PGenerator"
DEVICES_VIDEO="/dev/vhci /dev/vchiq"
PERL="/usr/bin/perl"
FB0_BLANK_FILE="/sys/class/graphics/fb0/blank"

case "$1" in
    start)
        echo -n "Starting $PROGRAM_NAME..."
        # Self-heal privileged command access after OTA installs. If a prior
        # archive left the sudoers include with the wrong mode/owner, meter
        # detection, reboot, and update actions from the WebUI will fail.
        chown root.root /etc/sudo /etc/sudo/sudoers.d /etc/sudo/sudoers.d/PGenerator /etc/sudoers.d /etc/sudoers.d/PGenerator 2>/dev/null
        chmod 755 /etc/sudo /etc/sudo/sudoers.d /etc/sudoers.d 2>/dev/null
        chmod 440 /etc/sudo/sudoers.d/PGenerator /etc/sudoers.d/PGenerator 2>/dev/null
        chmod +x /usr/sbin/pgenerator-update /usr/bin/spotread /usr/bin/spotread_wrapper.sh /usr/bin/meter_session.sh /usr/bin/meter_series.sh /usr/bin/ccss_create.py /usr/bin/ccss_create_patch.sh /usr/bin/ccxxmake_interactive 2>/dev/null
        # Open up /sys/kernel/debug so the renderer-spawn race fix
        # (wait_for_drm_master_unowned in command.pm) can poll
        # /sys/kernel/debug/dri/1/clients to wait for the kernel to
        # release DRM master. The debugfs root defaults to mode 700
        # (root-only); mode 755 makes the tree traversable for the
        # pgenerator user, and the per-file mode 444 limits actual
        # disclosure to read access on the few files the daemon
        # enumerates (and the file contents are small/ephemeral).
        # On a Pi4-only image this is acceptable; on a multi-tenant
        # box, narrow this to a more restrictive ACL.
        chmod 755 /sys/kernel/debug 2>/dev/null
        mkdir -p $PGENERATOR_VAR_DIR $PGENERATOR_MOUNT_POINT_DIR 2>/dev/null
        chown $PGENERATOR_USER_GROUP.$PGENERATOR_USER_GROUP $PGENERATOR_VAR_DIR $PGENERATOR_MOUNT_POINT_DIR 2>/dev/null
        chmod 775 $PGENERATOR_VAR_DIR 2>/dev/null
        chmod 770 $PGENERATOR_MOUNT_POINT_DIR 2>/dev/null
        mkdir -p $PGENERATOR_VAR_DIR/tmp $PGENERATOR_VAR_DIR/images $PGENERATOR_VAR_DIR/video $PGENERATOR_VAR_DIR/video/.diagseq $PGENERATOR_VAR_DIR/ccss $PGENERATOR_VAR_DIR/ccss/custom $PGENERATOR_VAR_DIR/updates 2>/dev/null
        chown $PGENERATOR_USER_GROUP.$PGENERATOR_USER_GROUP $PGENERATOR_VAR_DIR/tmp $PGENERATOR_VAR_DIR/images $PGENERATOR_VAR_DIR/video $PGENERATOR_VAR_DIR/video/.diagseq $PGENERATOR_VAR_DIR/ccss $PGENERATOR_VAR_DIR/ccss/custom $PGENERATOR_VAR_DIR/updates 2>/dev/null
        chmod 755 $PGENERATOR_VAR_DIR/tmp $PGENERATOR_VAR_DIR/ccss $PGENERATOR_VAR_DIR/ccss/custom $PGENERATOR_VAR_DIR/updates 2>/dev/null
        chmod 775 $PGENERATOR_VAR_DIR/images $PGENERATOR_VAR_DIR/video $PGENERATOR_VAR_DIR/video/.diagseq 2>/dev/null
        mkdir -p $PGENERATOR_VAR_DIR/lg $PGENERATOR_VAR_DIR/lg/ddc $PGENERATOR_VAR_DIR/lg/luts $PGENERATOR_VAR_DIR/lg/pin-sessions 2>/dev/null
        chown -R $PGENERATOR_USER_GROUP.$PGENERATOR_USER_GROUP $PGENERATOR_VAR_DIR/lg 2>/dev/null
        chmod 775 $PGENERATOR_VAR_DIR/lg $PGENERATOR_VAR_DIR/lg/ddc $PGENERATOR_VAR_DIR/lg/luts $PGENERATOR_VAR_DIR/lg/pin-sessions 2>/dev/null
        if [ ! -d "$PGENERATOR_PID_DIR" ]; then
         mkdir $PGENERATOR_PID_DIR
        fi
        if ! mountpoint -q $PGENERATOR_MOUNT_POINT_DIR ;then
         mount -t tmpfs -o user,mode=0770,size=$PGENERATOR_TMPFS_SIZE,uid=$PGENERATOR_USER_GROUP,gid=$PGENERATOR_USER_GROUP $PGENERATOR_MOUNT_POINT_NAME $PGENERATOR_MOUNT_POINT_DIR
        fi
        mkdir -p $PGENERATOR_MOUNT_POINT_DIR/tmp 2>/dev/null
        touch $PGENERATOR_MOUNT_POINT_DIR/operations.txt 2>/dev/null
        chown $PGENERATOR_USER_GROUP.$PGENERATOR_USER_GROUP $PGENERATOR_MOUNT_POINT_DIR/operations.txt $PGENERATOR_MOUNT_POINT_DIR/tmp 2>/dev/null
        if [ -e /var/lib/PGenerator/operations.txt ] && [ ! -L /var/lib/PGenerator/operations.txt ]; then
         rm -f /var/lib/PGenerator/operations.txt
        fi
        if [ ! -L /var/lib/PGenerator/operations.txt ]; then
         ln -sfn running/operations.txt /var/lib/PGenerator/operations.txt
        fi
        if [ -e "/dev/dri/card0" ];then
         mknod /dev/dri/renderD128 c 226 128 2>/dev/null
        fi
        chown $PGENERATOR_USER_GROUP.$PGENERATOR_USER_GROUP -R $PGENERATOR_PID_DIR
        chown $PGENERATOR_USER_GROUP.$PGENERATOR_USER_GROUP $DEVICES_VIDEO 2>/dev/null
        chmod 660 /dev/cec* 2>/dev/null
        chown $PGENERATOR_USER_GROUP.$PGENERATOR_USER_GROUP /dev/cec* 2>/dev/null
        # Pre-set the HDR_OUTPUT_METADATA connector property from
        # /etc/PGenerator/PGenerator.conf so the LG C2 (and other LG OLEDs)
        # does not apply a near-black lift when min_dml=0 is on the wire.
        # pgsethdr uses DRM_IOCTL_SET_MASTER/DROP_MASTER so it can run
        # after the renderer is already up; the call is idempotent. This
        # runs before the daemon (which forks the renderer) so pgsethdr
        # is the initial DRM master; subsequent pgsethdr calls from the
        # WebUI HDR update path run while the renderer holds the master
        # and steal/release it.
        if [ -x "/usr/bin/pgsethdr" ]; then
         /usr/bin/pgsethdr 2>/dev/null || echo "pgsethdr pre-set failed"
        fi
        setcap cap_net_bind_service=+ep $PERL
        setsid sudo -u $PGENERATOR_USER_GROUP $PROGRAM_DAEMON_SOCKET
        setcap cap_net_bind_service=-ep $PERL
        if [ -e "$FB0_BLANK_FILE" ]; then
         echo 1 > $FB0_BLANK_FILE
        fi
        $PROGRAM_CLIENT_SERIAL &
        # CEC: wake TV and select input on boot
        if [ -x "/usr/sbin/pgenerator-cec" ] && [ -e "/dev/cec0" ]; then
         /usr/sbin/pgenerator-cec wake >/dev/null 2>&1 &
        fi
        echo "done"
    ;;

    stop)
        echo -n "Stopping $PROGRAM_NAME..."
        /usr/bin/pkill -9 -f $PROGRAM_DAEMON_SOCKET 2>/dev/null
        /usr/bin/pkill -9 -f $PROGRAM_DAEMON_VIDEO 2>/dev/null
        /usr/bin/pkill -9 -f $PROGRAM_CLIENT_CMD 2>/dev/null
        /usr/bin/pkill -9 -f $PROGRAM_CLIENT_SERIAL 2>/dev/null
        umount $PGENERATOR_MOUNT_POINT_DIR 2>/dev/null
        chown root.root $DEVICES_VIDEO 2>/dev/null
        if [ -e "$FB0_BLANK_FILE" ]; then
         echo 0 > $FB0_BLANK_FILE
        fi
        echo "done"
    ;;

    restart)
        $0 stop
        $0 start
     ;;

    *)
        echo "Usage: /etc/init.d/$INIT_NAME {start|stop|restart}" >&2
        exit 1
    ;;
esac
