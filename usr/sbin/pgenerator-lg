$DEFAULT_CONNECT_TIMEOUT=5;
$DEFAULT_PAIR_TIMEOUT=55;
$MAX_FRAME_SIZE=1024*1024;
$LG_DEFAULT_APP_ID="com.lge.test";
$LG_DEFAULT_APP_NAME="LG Remote App";
$LG_CURRENT_APP_ID=$LG_DEFAULT_APP_ID;
$LG_CURRENT_APP_NAME=$LG_DEFAULT_APP_NAME;
$LG_REMOTE_APP_SIGNATURE=(
